<main class="container">
  <article>
    <h2><%= t('users.auth.new.heading') %></h2>
    <% if error %>
      <p><%= error %></p>
    <% end %>
    <form action="/session" method="post" data-turbo="false">
      <%= csrf_field %>
      <label>
        <%= t('users.auth.new.email_label') %>
        <input type="email" name="email" required/>
      </label>
      <label>
        <%= t('users.auth.new.password_label') %>
        <input type="password" name="password" required/>
      </label>
      <button type="submit"><%= t('users.auth.new.submit_button') %></button>
    </form>
    <p><a href="/register"><%= t('users.auth.new.register_link') %></a></p>
  </article>
</main>
