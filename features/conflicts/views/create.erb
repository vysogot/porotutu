<turbo-stream action="prepend" target="conflicts-drafts">
  <template>
    <%= conflicts_erb :show, layout: false, locals: { conflict:, current_user_id: } %>
  </template>
</turbo-stream>
<turbo-stream action="update" target="new_conflict_frame">
  <template>
    <p>Conflict added to your drafts. <a href="/conflicts/new">Add another</a></p>
  </template>
</turbo-stream>
