<turbo-frame id="pending-partner">
  <article>
    <header><h3>Are you ready to see their conflicts?</h3></header>
    <form method="post" action="/conflicts/reveal">
      <fieldset>
        <label>
          <input type="checkbox" required/>
          I am in a calm, open headspace
        </label>
        <label>
          <input type="checkbox" required/>
          I have time to talk this through
        </label>
        <label>
          <input type="checkbox" required/>
          I am willing to listen without interrupting
        </label>
        <label>
          <input type="checkbox" required/>
          I commit to working toward resolution
        </label>
      </fieldset>
      <div class="grid">
        <button type="submit">I'm ready</button>
        <a href="/conflicts" role="button" class="secondary outline">Not yet</a>
      </div>
    </form>
  </article>
</turbo-frame>
