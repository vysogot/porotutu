<main class="container" id="new_conflict_frame">
  <h2>New conflict</h2>
  <form action="/conflicts" method="post">
      <label for="title">
        What's it about?
        <input
          type="text"
          id="title"
          name="title"
          placeholder="e.g. Who does the dishes"
          maxlength="100"
          value="<%= defined?(params) ? params[:title] : '' %>"
          autofocus
        />
        <%= field_error(:title, errors: defined?(errors) ? errors : nil) %>
      </label>
      <label for="description">
        Describe the conflict
        <textarea
          id="description"
          name="description"
          placeholder="Give some context..."
          maxlength="1000"
          rows="4"
        ><%= defined?(params) ? params[:description] : '' %></textarea>
        <%= field_error(:description, errors: defined?(errors) ? errors : nil) %>
      </label>
      <label for="favor">
        What's the favor that would settle this?
        <input
          type="text"
          id="favor"
          name="favor"
          placeholder="e.g. The other person cooks for a week"
          maxlength="100"
          value="<%= defined?(params) ? params[:favor] : '' %>"
        />
        <%= field_error(:favor, errors: defined?(errors) ? errors : nil) %>
      </label>
      <div class="grid">
        <button type="submit">Create conflict</button>
        <a href="/conflicts" role="button" class="secondary outline">Cancel</a>
      </div>
  </form>
</main>
