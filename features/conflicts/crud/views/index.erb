<main class="container" id="conflicts-container">
  <header class="container">
    <hgroup>
      <h1>Couple of Conflicts</h1>
      <p>Track and resolve conflicts together.</p>
      <nav>
        <a href="/conflicts/new" role="button" class="outline">+ New conflict</a>
      </nav>
    </hgroup>
  </header>

  <% if drafts.empty? %>
    <article>
      <p>No conflicts yet. Start one to get the conversation going.</p>
    </article>
  <% end %>

  <% unless drafts.empty? %>
    <section id="conflicts-drafts-section">
      <h2>Your drafts</h2>
      <div id="conflicts-drafts">
        <% drafts.each do |conflict| %>
          <%= view :_card, layout: false, locals: { conflict: } %>
        <% end %>
      </div>
    </section>
  <% end %>
</main>
